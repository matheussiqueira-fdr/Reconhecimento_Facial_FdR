# Copie para .env e ajuste os valores

# Porta da API/servidor
PORT=3000

# Segredo para assinatura dos tokens JWT (TROQUE em produção)
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h

# Caminho do arquivo do banco SQLite
DB_PATH=./data/app.db

# Limiar de distância euclidiana para considerar "match" (face-api.js).
# Quanto menor, mais rígido. 0.6 é o padrão recomendado pela face-api.js.
MATCH_THRESHOLD=0.55

# Credenciais do admin inicial criado pelo seed
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=admin123
